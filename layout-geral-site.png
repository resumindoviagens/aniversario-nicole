import { CalendarDays, Clock, MapPin, Sparkles } from 'lucide-react';

export function EventCard() {
  const items = [
    { icon: CalendarDays, label: 'Data', value: '07/06/2026' },
    { icon: Clock, label: 'Horário', value: '17 horas' },
    { icon: MapPin, label: 'Local', value: 'Informar endereço do buffet' },
    { icon: Sparkles, label: 'Tema', value: 'Uma viagem divertida com a Nicole' }
  ];
  return (
    <div className="grid gap-4 sm:grid-cols-2">
      {items.map(({ icon: Icon, label, value }) => (
        <div key={label} className="rounded-3xl bg-white/85 p-5 shadow-soft ring-1 ring-white/70">
          <Icon className="mb-3 h-7 w-7 text-nicolePink" />
          <p className="text-xs font-black uppercase tracking-[.22em] text-nicoleGold">{label}</p>
          <p className="mt-1 text-lg font-black text-nicoleBlue">{value}</p>
        </div>
      ))}
    </div>
  );
}
